# ============================================================
# Operant — Environment Variables
# Copy this to .env.local for local dev.
# Set all of these in Vercel → Settings → Environment Variables.
# ============================================================

# ── Supabase (auth only) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Used by the auth callback redirect
NEXT_PUBLIC_SITE_URL=https://operantai.xyz
# Local dev only — overrides the redirect URL in signUp
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ── AWS Aurora PostgreSQL ────────────────────────────────────
# Hostname of your Aurora cluster endpoint
PGHOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
PGDATABASE=postgres
PGUSER=postgres
AWS_REGION=us-east-1
# IAM role ARN that Vercel OIDC will assume to get RDS auth tokens
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-vercel-rds-role

# ── Stripe ───────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Register endpoint: https://operantai.xyz/api/webhooks/stripe
# Events to subscribe: checkout.session.completed, payment_intent.payment_failed, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI (powers all chat routes via Vercel AI SDK) ────────
OPENAI_API_KEY=sk-...

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://operantai.xyz
