# ============================================================
# Operant - Environment Variables
# Copy this to .env.local for local dev.
# Set all of these in Vercel -> Settings -> Environment Variables.
# ============================================================

# Supabase (auth only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Used by the auth callback redirect. Match NEXT_PUBLIC_APP_URL in production.
NEXT_PUBLIC_SITE_URL=https://operant.xyz
# Local dev only - overrides the redirect URL in signUp
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# AWS Aurora PostgreSQL
# Hostname of your Aurora cluster endpoint
PGHOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
PGDATABASE=postgres
PGUSER=postgres
AWS_REGION=us-east-1
# IAM role ARN that Vercel OIDC will assume to get RDS auth tokens
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-vercel-rds-role

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe Dashboard -> Webhooks -> your endpoint -> Signing secret
# Register endpoint: https://operant.xyz/api/webhooks/stripe
# Events to subscribe: checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, checkout.session.expired,
# payment_intent.payment_failed, charge.refunded, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_...

# AI Gateway (powers all chat routes server-side)
AI_GATEWAY_API_KEY=vck_...
# On Vercel, VERCEL_OIDC_TOKEN can satisfy AI Gateway auth when enabled.

# App
NEXT_PUBLIC_APP_URL=https://operant.xyz
# Protects /api/readiness. Use a long random value.
READINESS_TOKEN=replace-with-a-long-random-token
# Protects /api/db-setup migration runner. Use only during setup/migrations.
SETUP_TOKEN=replace-with-a-long-random-token
